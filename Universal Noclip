local fadeInText = TweenService:Create(creditLabel, tweenInfo, {TextTransparency = 0})

fadeInBg:Play()
fadeInText:Play()

task.wait(5)

local fadeOutBg   = TweenService:Create(introFrame,   tweenInfo, {BackgroundTransparency = 1})
local fadeOutText = TweenService:Create(creditLabel, tweenInfo, {TextTransparency = 1})
